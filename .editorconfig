root = true

[*.cs]

########################################
# Общие правила
########################################

indent_style = space
indent_size = 4
end_of_line = crlf

########################################
# using
########################################

dotnet_sort_system_directives_first = true:error
dotnet_separate_import_directive_groups = true:error

########################################
# var vs explicit
########################################

csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

########################################
# Скобки и форматирование
########################################

csharp_new_line_before_open_brace = all:warning

########################################
# Поля и readonly
########################################

dotnet_style_readonly_field = true:warning

########################################
# Expression-bodied
########################################

csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

########################################
# null-checks
########################################

csharp_style_throw_expression = true:suggestion
csharp_style_null_propagation = true:suggestion

########################################
# Анализаторы (важные)
########################################

dotnet_diagnostic.IDE0005.severity = warning   # лишние using
dotnet_diagnostic.IDE0044.severity = warning   # readonly
dotnet_diagnostic.IDE0051.severity = warning   # неиспользуемые методы
dotnet_diagnostic.CS0168.severity = warning    # неиспользуемые переменные